{
    "name": "stevenpaw/experiencelogger",
    "type": "silverstripe-recipe",
    "description": "A tool for counting experiences",
    "require": {
        "php": "^8.3",
        "silverstripe/recipe-plugin": "^2",
        "silverstripe/recipe-cms": "^6.2",
        "ext-json": "*",
        "colymba/gridfield-bulk-editing-tools": "^5.2",
        "undefinedoffset/sortablegridfield": "^3.0",
        "jonom/focuspoint": "^6.0",
        "dnadesign/silverstripe-elemental-userforms": "^5.1",
        "purplespider/silverstripe-basic-gallery-extension": "^5.0",
        "stevenpaw/silverstripe-cms-backend-theme": "^1.1",
        "stevenpaw/ss5-duplicate-dataobject": "dev-updateto6",
        "atwx/silverstripe-vitehelper": "^1.6"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:stevenpaw/ss5-duplicate-dataobject.git"
        }
    ],
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.6",
        "wernerkrauss/silverstripe-rector": "^1.3",
        "cambis/silverstan": "^2.2",
        "phpstan/extension-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/src/"
        }
    },
    "extra": {
        "expose": [
            "app/client/dist",
            "app/client/src/images",
            "app/client/icons"
        ],
        "resources-dir": "_resources",
        "project-files-installed": [
            "app/.htaccess",
            "app/_config.php",
            "app/_config/mimevalidator.yml",
            "app/_config/mysite.yml",
            "app/src/Page.php",
            "app/src/PageController.php"
        ],
        "public-files-installed": [
            ".htaccess",
            "index.php",
            "web.config"
        ]
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "scripts": {
        "lint": "vendor/bin/phpcs",
        "fix": "vendor/bin/phpcbf",
        "rector": "vendor/bin/rector -v",
        "rector-dry": "vendor/bin/rector -v --dry-run",
        "phpstan": "vendor/bin/phpstan"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true,
            "kylekatarnls/update-helper": true,
            "phpstan/extension-installer": true
        }
    }
}
